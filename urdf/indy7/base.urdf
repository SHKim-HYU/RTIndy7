<?xml version="1.0" ?>
<robot name="box" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="black">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>  
	<link name="base_link">
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
        			<mesh filename="meshes/visual/base.stl"/>
			</geometry>
		<material name="black"/>
		</visual>

	</link>
</robot>
